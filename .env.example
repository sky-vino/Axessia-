# ======================================================
# AXESSIA – Environment Variables Reference
# ======================================================
# DO NOT fill real values here.
# Set these in Azure Portal → App Service →
# Configuration → Application Settings
# ======================================================

# Azure OpenAI — get from portal.azure.com
# Resource → Keys and Endpoint
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE-NAME.openai.azure.com/
AZURE_OPENAI_KEY=your-azure-openai-key-here
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# Axessia API Security
# Generate a strong random string — e.g. use: python -c "import secrets; print(secrets.token_hex(32))"
AXESSIA_API_KEY=generate-a-strong-random-key-here

# Internal API URLs (leave as-is for Azure App Service single-instance)
AXESSIA_API_URL=http://127.0.0.1:8001/scan
AXESSIA_CRAWL_URL=http://127.0.0.1:8001/crawl

# CORS — comma-separated list of allowed frontend origins
# Replace with your actual App Service URL after deploy
AXESSIA_ALLOWED_ORIGINS=https://YOUR-APP-NAME.azurewebsites.net

# Azure App Service internal settings (set these in Configuration too)
WEBSITES_PORT=8000
SCM_DO_BUILD_DURING_DEPLOYMENT=true
PLAYWRIGHT_BROWSERS_PATH=/home/playwright-browsers
